# KING STUDIO — environment variable template (PRD §7.12).
# Copy to `.env` (gitignored) and fill values. NEVER commit real secrets — CLAUDE.md §3.7:
# secrets live in Vercel Environment Variables only.

# --- App ---
NEXT_PUBLIC_SITE_URL=
NODE_ENV=development
# E2E reserved port = 3100 (local :3000 is permanently held by a separate app, mk-artist-db).
# Playwright runs `pnpm dev --port 3100`; global-setup asserts /api/health app==='kingstudio'.
# (Port coexistence with mk-artist-db is a cross-project agreement — not yet finalized.)

# --- DB · Cache ---
DATABASE_URL=
# DATABASE_URL_REPLICA=   # v1.1
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# --- Payment ---
KG_INICIS_MID=
KG_INICIS_SIGN_KEY=
KG_INICIS_API_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
OPENEXCHANGERATES_APP_ID=
POPBILL_LINK_ID=
POPBILL_SECRET_KEY=
POPBILL_CORP_NUM=

# --- Auth (Auth.js v5) ---
AUTH_SECRET=                       # `openssl rand -base64 33` (prod: GCP Secret Manager)
# Admin TOTP-at-rest key — MUST base64-decode to exactly 32 bytes: `openssl rand -base64 32`
ADMIN_TOTP_ENC_KEY=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=
AUTH_APPLE_TEAM_ID=
AUTH_APPLE_KEY_ID=
AUTH_APPLE_PRIVATE_KEY=
# AUTH_LINE_ID=           # v1.1
# AUTH_LINE_SECRET=       # v1.1
# AUTH_KAKAO_ID=          # v1.1
# AUTH_KAKAO_SECRET=      # v1.1

