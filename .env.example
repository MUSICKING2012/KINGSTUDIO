# KING STUDIO — environment variable template (PRD §7.12 · infra pivot 2026-07-18).
# Copy to `.env` (gitignored) and fill values. NEVER commit real secrets — CLAUDE.md §3.7:
# prod secrets live in Railway environment variables (service-scoped) only.

# --- App ---
NEXT_PUBLIC_SITE_URL=
NODE_ENV=development
# E2E reserved port = 3100 (local :3000 is permanently held by a separate app, mk-artist-db).
# Playwright runs `pnpm dev --port 3100`; global-setup asserts /api/health app==='kingstudio'.
# (Port coexistence with mk-artist-db is a cross-project agreement — not yet finalized.)

# --- DB · Cache ---
DATABASE_URL=
# DATABASE_URL_REPLICA=   # v1.1
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# --- Payment ---
KG_INICIS_MID=
KG_INICIS_SIGN_KEY=
KG_INICIS_API_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
OPENEXCHANGERATES_APP_ID=
POPBILL_LINK_ID=
POPBILL_SECRET_KEY=
POPBILL_CORP_NUM=

# --- Auth (Auth.js v5) ---
AUTH_SECRET=                       # `openssl rand -base64 33` (prod: Railway env vars)
# Admin TOTP-at-rest key — MUST base64-decode to exactly 32 bytes: `openssl rand -base64 32`
ADMIN_TOTP_ENC_KEY=                # `openssl rand -base64 32` (seed-env-1; 선행 주입 필수)

# --- Super Admin 시딩 (seed-env-2) ---
# pnpm seed:admin 실행 전 주입. .env 로컬 전용(gitignored). 실값 여기 넣지 말 것.
# 주의: upsert는 email 매칭 — 한 번 시딩된 행의 totp/pw는 재시드로 교체 불가.
#       변경 필요 시: DB에서 admin_users 행 삭제 후 재실행.
SEED_ADMIN_EMAIL=                  # 예: admin@kingstudio.co.kr
SEED_ADMIN_PASSWORD=               # ≥12자 평문 (bcrypt는 시드가 처리)
SEED_ADMIN_TOTP_SECRET=            # base32 16자. 최초 1회만 생성·주입. 이미 시딩됐으면 재생성 금지(위 경고: 교체 시 DB 행 삭제 후 재시드). 생성: node -e "console.log(require('otplib').authenticator.generateSecret())"

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=
AUTH_APPLE_TEAM_ID=
AUTH_APPLE_KEY_ID=
AUTH_APPLE_PRIVATE_KEY=
# AUTH_LINE_ID=           # v1.1
# AUTH_LINE_SECRET=       # v1.1
# AUTH_KAKAO_ID=          # v1.1
# AUTH_KAKAO_SECRET=      # v1.1

# --- Files · Media (Supabase Storage — infra pivot 2026-07-18, Infra_Pivot_Decision_v1) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=         # 서버 전용 — 클라이언트 번들 유입 금지 (NEXT_PUBLIC_ 금지)
SUPABASE_BUCKET_CONTENT=           # 비공개 버킷 — 서명 URL(TTL 10분)로만 서빙 (하드제약 #5)
SUPABASE_BUCKET_CONSENT=           # 비공개 버킷 — 동의 PDF (해시 무결성, 하드제약 #1 / 피벗 D1)

